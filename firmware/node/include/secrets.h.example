/**
 * secrets.h.example — copy to secrets.h and fill in real values.
 * secrets.h is git-ignored; never commit real TTN credentials.
 */

#pragma once

// TTN OTAA credentials (obtained from TTN console)
// Format: MSB first, 16 hex bytes each
#define DEVEUI  { 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00 }
#define APPEUI  { 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00 }
#define APPKEY  { 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, \
                  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00 }
